{
  "db_name": "PostgreSQL",
  "query": "\n                SELECT uuid, sender_person_uuid,  scene_uuid, content, sent_at\n                FROM message\n                WHERE scene_uuid = $1::UUID\n                  AND ($2::timestamptz IS NULL OR sent_at < $2::timestamptz)\n                ORDER BY sent_at DESC\n                LIMIT $3\n            ",
