  "query": "\n                SELECT uuid,\n                       person_uuid,\n                       content,\n                       success_condition,\n                       abandon_condition,\n                       failure_condition,\n                       priority,\n                       created_at,\n                       completed_at,\n                       abandoned_at,\n                       failed_at\n                FROM person_task\n                WHERE uuid = $1::UUID\n                  AND person_uuid = $2::UUID\n                  AND completed_at IS NULL\n                  AND abandoned_at IS NULL\n                  AND failed_at IS NULL;\n            ",
