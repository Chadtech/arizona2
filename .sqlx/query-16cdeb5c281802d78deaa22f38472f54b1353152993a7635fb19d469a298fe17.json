{
  "db_name": "PostgreSQL",
  "query": "\n                        SELECT uuid, sender_person_uuid, content, sent_at\n                        FROM message\n                        WHERE scene_uuid = $1::UUID\n                          AND sent_at >= $2\n                          AND ($3::timestamptz IS NULL OR sent_at <= $3::timestamptz)\n                        ORDER BY sent_at\n                        ",
